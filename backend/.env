# Application
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=change_me_to_a_very_long_random_secret_at_least_64_chars
JWT_EXPIRES_IN=4h
JWT_REFRESH_SECRET=change_me_to_another_very_long_random_secret_at_least_64_chars
JWT_REFRESH_EXPIRES_IN=7d

# Database — SQLite (dev)
DB_TYPE=sqlite
DB_DATABASE=trashsmart.db

# Database — PostgreSQL (prod, décommentez pour la production)
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=trashsmart
# DB_PASSWORD=secret
# DB_DATABASE=trashsmart

# CORS
FRONTEND_URL=http://localhost:4200
